# Web-mode build (the website served from the trusted central origin).
# Loaded ONLY by `vite build --mode web` (npm run build:web). The normal
# `npm run build` never sees this, so VITE_OH_WEB is undefined there and every
# `if (import.meta.env.VITE_OH_WEB)` branch — plus the dynamically-imported
# web backend it guards — is dead-code-eliminated from the local download.
VITE_OH_WEB=1

# The website can't host the 60-100 MB pmtiles on Cloudflare Pages (25 MB/file
# limit), so map tiles load from the registry Worker's CORS+range proxy, which
# streams them from the canonical GitHub Release. Nodes (when published) are
# tried first and verified by hash; this is the always-available fallback.
VITE_OH_PMTILES_URL=https://open-historia-registry.nichojkrol.workers.dev/content

# Use the LIVE signed node directory from the registry Worker (updates as nodes
# are accepted/paused/banned), not the stale copy bundled at build time.
VITE_OH_DIRECTORY_URL=https://open-historia-registry.nichojkrol.workers.dev/node-directory.json

# Community hub GitHub proxy (SSRF-guarded /hub/file on the registry Worker) —
# GitHub attachments/release assets send no CORS headers, so bundle downloads
# must go through it. Listing still hits api.github.com directly.
VITE_OH_HUB_URL=https://open-historia-registry.nichojkrol.workers.dev

# Accounts + encrypted sync (magic-link identity; games/scenarios sync as blobs
# encrypted client-side). Points at the registry Worker's /account/* + /sync/*.
VITE_OH_ACCOUNT_URL=https://open-historia-registry.nichojkrol.workers.dev
